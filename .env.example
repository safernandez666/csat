# CSAT Environment Configuration
# Copy this file to .env and adjust values for production

# Backend
# Set CSAT_ENV=prod and a real SECRET_KEY before deploying.
# In prod the app refuses to start with the default SECRET_KEY.
CSAT_ENV=dev
# Generate a real secret key with:
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///app/data/csat.db
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost
UPLOAD_DIR=./uploads
SCHEDULER_ENABLED=true
# Set COOKIE_SECURE=true once you serve the app over HTTPS.
COOKIE_SECURE=false

# Argon2 settings
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=1

# OIDC integrations (optional)
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_ISSUER_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER_URL=

# AI providers — configured at runtime via Settings → AI in the UI.
# Supported: openai, anthropic, openrouter, ollama (run your own externally).
# AI_DEFAULT_URL only seeds the FIRST install if no setting exists yet.
# AI_DEFAULT_URL=http://host.docker.internal:11434
